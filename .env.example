ENV=dev
LOG_LEVEL=INFO

# Storage
SQL_URL=postgresql+asyncpg://rag:ragpass@localhost:5432/ragdocs
MONGO_URL=mongodb://localhost:27017
MONGO_DB=ragdocs
REDIS_URL=redis://localhost:6379/0
CHROMA_DIR=./data/chroma

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
EMBEDDING_BACKEND=onnx   # all-MiniLM-L6-v2 on onnxruntime, no torch
# EMBEDDING_BACKEND=sentence_transformers  # GPU only; needs an extra install

# LLM — ollama needs no key; switch to openai for hosted inference
LLM_BACKEND=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b   # 8b needs ~8GB RAM; 1b runs on a small Codespace
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Cache
CACHE_ENABLED=true
CACHE_TTL_S=3600
MAX_UPLOAD_MB=25
